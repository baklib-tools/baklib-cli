{
  "name": "@baklib/baklib-cli",
  "version": "0.5.0",
  "description": "Baklib Open API CLI — 数据录入、主题本地预览（Open API + Vite/React 面板）",
  "type": "module",
  "bin": {
    "baklib": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "theme-preview",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.js",
    "theme-preview:install": "npm install --prefix theme-preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^4.4.1",
    "cfonts": "^3.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "form-data": "^4.0.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "baklib",
    "cli",
    "dam",
    "knowledge-base",
    "liquid",
    "theme"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baklib-tools/baklib-cli.git"
  },
  "homepage": "https://github.com/baklib-tools/baklib-cli#readme",
  "bugs": {
    "url": "https://github.com/baklib-tools/baklib-cli/issues"
  }
}
