{
  "name": "baklib-cli",
  "version": "0.1.0",
  "description": "Baklib Open API CLI — 数据录入、主题本地预览（API + React + Liquid）",
  "type": "module",
  "bin": {
    "baklib": "dist/index.js"
  },
  "files": [
    "dist",
    "theme-preview",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.js",
    "theme-preview:install": "npm install --prefix theme-preview"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "form-data": "^4.0.0",
    "liquidjs": "^10.21.1",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "baklib",
    "cli",
    "dam",
    "knowledge-base",
    "liquid",
    "theme"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baklib/baklib-cli.git"
  }
}
